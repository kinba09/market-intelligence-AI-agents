# Core
APP_ENV=dev
API_PREFIX=/api
APP_SECRET_KEY=change-this-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=10080
SCHEDULER_INTERVAL_MINUTES=30

# Gemini defaults (fallback if user has not added BYOK key)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/embedding-001

# Postgres
DATABASE_URL=postgresql+psycopg2://market:market@postgres:5432/market_intel

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=market_chunks
VECTOR_SIZE=768

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200
OPENSEARCH_USER=
OPENSEARCH_PASSWORD=
OPENSEARCH_INDEX=market_chunks

# MinIO
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_RAW=market-intel-raw

# Alert thresholds
ALERT_IMPORTANCE_HIGH=0.75
ALERT_CONFIDENCE_HIGH=0.70
ALERT_IMPORTANCE_MEDIUM=0.60
ALERT_CONFIDENCE_MEDIUM=0.55
